# IBM watsonx.ai Config (Dallas Region)
WATSONX_BASE_URL=https://base-url-of-your-watsonx-ai-service
IBM_CLOUD_API_KEY=your_ibm_cloud_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# Backend Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Frontend URL (for CORS) - Comma-separated list for multiple origins
# Development:
FRONTEND_URL=http://localhost:5173

# Production (replace with your actual domains):
# FRONTEND_URL=https://your-frontend-domain.com,https://www.your-frontend-domain.com

# Frontend API Base URL
# Development (uses localhost):
VITE_API_BASE_URL=http://localhost:3000

# Production Options:
# Option 1: Same-origin deployment (frontend and backend on same domain)
# Leave VITE_API_BASE_URL unset or empty - the app will use window.location.origin
# VITE_API_BASE_URL=

# Option 2: Different domains (e.g., api.yourdomain.com)
# VITE_API_BASE_URL=https://api.yourdomain.com

# Option 3: Deployed backend URL (e.g., Heroku, Railway, etc.)
# VITE_API_BASE_URL=https://your-backend-app.herokuapp.com

# Cache Configuration
CACHE_TTL=3600
TEMP_DIR=/tmp/bobinsight

# Rate Limiting
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=60000
