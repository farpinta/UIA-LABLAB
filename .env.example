# IBM Bob API Configuration
# watsonx.ai Config (Dallas Region)
WATSONX_BASE_URL=https://us-south.ml.cloud.ibm.com
IBM_CLOUD_API_KEY=_API_Key__IBM_Cloud
WATSONX_PROJECT_ID=_Project_ID_watsonx

# Backend Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Cache Configuration
CACHE_TTL=3600
TEMP_DIR=/tmp/bobinsight

# Rate Limiting
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=60000
