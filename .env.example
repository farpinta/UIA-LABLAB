# IBM watsonx.ai Config (Dallas Region)
WATSONX_BASE_URL=https://base-url-of-your-watsonx-ai-service
IBM_CLOUD_API_KEY=your_ibm_cloud_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# Backend Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Frontend URL (for CORS) - Comma-separated list for multiple origins
# Development example:
FRONTEND_URL=http://localhost:5173
# Production example (explicitly list allowed origins, avoid wildcards):
# FRONTEND_URL=https://uia-bobinsight.pinont.me,https://app.pinont.me

# Frontend API Base URL (for production deployment)
VITE_API_BASE_URL=http://localhost:3000

# Cache Configuration
CACHE_TTL=3600
TEMP_DIR=/tmp/bobinsight

# Rate Limiting
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=60000
